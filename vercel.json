{
  "regions": ["hnd1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-schedule-reminder",
      "schedule": "0 9 * * 6"
    },
    {
      "path": "/api/cron/clock-reminder",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/closing-reminder",
      "schedule": "0 1 25 * *"
    }
  ]
}
