# ─────────────────────────────────────────────────────────────────────────────
# 環境変数テンプレート
# 使い方: cp .env.example .env.local  して実際の値を設定する
# ─────────────────────────────────────────────────────────────────────────────

# ── データベース ──────────────────────────────────────────────────────────────
# Supabase を使う場合:
#   DATABASE_URL  = Transaction Pooler (ポート 6543) ← アプリ・Vercel 用
#   DIRECT_URL    = Direct Connection (ポート 5432)  ← マイグレーション専用
#
# Settings → Database → Connection string → URI からコピーする
# NOTE:
#   1ページで複数APIを並列実行する設計では connection_limit=1 が直列化ボトルネックになることがあります。
#   まずは pooler + pgbouncer=true で運用し、必要に応じて接続数を調整してください。
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ローカル開発の場合:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/integrated_ops_dev?schema=public"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/integrated_ops_dev?schema=public"

# ── 認証 (Better Auth) ────────────────────────────────────────────────────────
# 暗号化キー（32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
BETTER_AUTH_SECRET="change-this-to-a-random-secret-key-at-least-32-chars"

# Better Auth のベース URL（API ルートの起点）
BETTER_AUTH_URL="http://localhost:3001"

# ── アプリケーション ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"

# ── Slack 連携 ────────────────────────────────────────────────────────────────
# Slack App の Bot Token（xoxb-...）
# SLACK_BOT_TOKEN="xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx"
#
# 通知先チャンネルID（省略時は SLACK_CHANNEL_DEFAULT にフォールバック）
# チャンネルID取得: Slack でチャンネル名を右クリック → チャンネル詳細 → 一番下の "C..." をコピー
# SLACK_CHANNEL_DEFAULT="C0123456789"    # 共通（フォールバック）
# SLACK_CHANNEL_SCHEDULE="C0123456789"   # 勤務予定登録通知
# SLACK_CHANNEL_ATTENDANCE="C0123456789" # 出退勤通知（出勤・退勤共通）

# ── Cron ジョブ認証（必須） ──────────────────────────────────────────────────
# Vercel Cron が Authorization: Bearer <secret> として送るトークン
# 未設定の場合、cron エンドポイントは全リクエストを 401 で拒否する
# 生成例: openssl rand -hex 32
CRON_SECRET="your-cron-secret"

# ── メール送信（招待メール等） ─────────────────────────────────────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"          # TLS の場合は "true"
# SMTP_USER="no-reply@example.com"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="no-reply@example.com"  # 省略時は SMTP_USER を使用

# ── LayerX（請求書の経費精算連携） ───────────────────────────────────────────
# LAYERX_EMAIL="accounting@example.com"  # 経費精算ツールへの転送先メールアドレス

# ── ファイルストレージ（Phase 3 で利用） ────────────────────────────────────────
# AWS_REGION="ap-northeast-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_BUCKET_NAME="integrated-ops-files"

# ── DocuSign 連携（Phase 3 で利用） ───────────────────────────────────────────
# DOCUSIGN_HMAC_KEY=""
# DOCUSIGN_INTEGRATION_KEY=""
# DOCUSIGN_ACCOUNT_ID=""
